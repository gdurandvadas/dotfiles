{
  "diff_view_style": "unified",
  "cli_default_open_behavior": "new_window",
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "group_by": "none",
    "dock": "left",
    "sort_by_path": true,
    "tree_view": true
  },
  "agent": {
    "dock": "right",
    "default_model": {
      "effort": "high",
      "provider": "copilot_chat",
      "model": "gpt-5.4",
    },
    "model_parameters": [],
  },
  "terminal": {
    "font_family": "FiraCode Nerd Font Propo",
  },
  "format_on_save": "on",
  "auto_install_extensions": {
    "nix": true,
    "sql": true,
    "glsl": true,
    "helm": true,
    "html": true,
    "make": true,
    "toml": true,
    "biome": true,
    "proto": true,
    "direnv": true,
    "kotlin": true,
    "clojure": true,
    "gdscript": true,
    "surrealql": true,
    "terraform": true,
    "catppuccin": true,
    "dockerfile": true,
    "catppuccin-icons": true,
    "claude-agent": true,
  },
  // Theming
  "theme": {
    "mode": "system",
    "light": "Catppuccin Frappé",
    "dark": "Catppuccin Mocha"
  },
  "icon_theme": {
    "mode": "system",
    "light": "Catppuccin Frappé",
    "dark": "Catppuccin Mocha",
  },
  // Typography
  "ui_font_size": 13,
  "buffer_font_size": 12.0,
  "agent_ui_font_size": 12,
  "agent_buffer_font_size": 12.0,

  // Agents
  "agent_servers": {
    "github-copilot-cli": {
      "default_config_options": {
        "model": "auto",
        "mode": "https://agentclientprotocol.com/protocol/session-modes#autopilot",
        "allow_all": "on"
      },
      "type": "registry"
    },
    "codex-acp": {
      "default_config_options": {
        "model": "gpt-5.5"
      },
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry",
    },
  },

  // Language-specific settings
  "languages": {
    "Go": {
      "language_servers": ["gopls"],
      "format_on_save": "on",
      "tab_size": 4,
    },
    "Rust": {
      "language_servers": ["rust-analyzer"],
      "format_on_save": "on",
    },
    "TypeScript": {
      "language_servers": ["vtsls"],
      "format_on_save": "on",
      "tab_size": 2,
    },
    "JavaScript": {
      "language_servers": ["vtsls"],
      "format_on_save": "on",
      "tab_size": 2,
    },
    "Nix": {
      "language_servers": ["nixd"],
      "format_on_save": "on",
      "tab_size": 2,
    },
  },
  // LSP overrides
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "checkOnSave": true,
        "check": {
          "command": "clippy",
        },
      },
    },
    "gopls": {
      "initialization_options": {
        "hints": {
          "parameterNames": true,
          "rangeVariableTypes": true,
        },
      },
    },
  },
}
