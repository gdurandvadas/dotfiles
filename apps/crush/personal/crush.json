{
  "$schema": "https://charm.land/crush.json",
  "providers": {
    "openai": {
      "type": "openai",
      "api_key": "$PERSONAL_OPENAI_API_KEY"
    }
  },
  "options": {
    "skills_paths": [
      "$HOME/.config/crush-personal/skills"
    ]
  },
  "permissions": {
    "allowed_tools": [
      "view",
      "ls",
      "grep",
      "glob",
      "edit"
    ]
  }
}
