// Zellij config for Alacritty: tabs, panes, compact bar.
// Unlock-first (non-colliding): press Ctrl+g to focus Zellij, then shortcut (e.g. t for tab).

// UI
pane_frames false
default_layout "compact"

// Mouse & copy
mouse_mode true
copy_clipboard "system"
copy_on_select true

// Theme (catppuccin-macchiato; matches dark theme)
theme "catppuccin-macchiato"

// Unlock-first: Zellij only grabs keys after Ctrl+g, so editor shortcuts (Ctrl+p etc.) work.
simplified_ui true
