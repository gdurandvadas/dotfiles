// Add this to your ~/.config/zellij/config.kdl

keybinds {
    // This defines what happens when the UI is "Locked" (the default)
    locked {
        bind "Ctrl g" { SwitchToMode "Normal"; }
    }
    // This defines what happens when you are in "Normal" mode
    // It allows you to hit Ctrl+g to immediately go back to "typing mode"
    shared_except "locked" {
        bind "Ctrl g" { SwitchToMode "Locked"; }
    }
}

// Keep your existing settings below
pane_frames false
default_layout "compact"
mouse_mode true
copy_clipboard "system"
copy_on_select true
theme "catppuccin-frappe"
