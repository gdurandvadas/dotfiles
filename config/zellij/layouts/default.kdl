// Default Zellij layout: compact bar + Code tab + Terminal tab (split).
// Used when creating a new session (e.g. "main" from Alacritty).
// denmo

layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:compact-bar"
        }
        children
    }

    tab name="Code" focus=true {
        pane
    }

    tab name="Terminal" {
        pane split_direction="vertical" {
            pane
            pane
        }
    }
}
