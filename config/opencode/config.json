{
  "$schema": "https://opencode.ai/config.json",
  "server": {
    "hostname": "127.0.0.1",
    "mdns": false
  },
  "default_agent": "plan",
  "model": "github-copilot/gpt-5-mini",
  "provider": {
    "github-copilot": {
      "models": {
        "claude-opus-4.6": { "name": "Claude Opus 4.6" },
        "claude-haiku-4.5": { "name": "Claude Haiku 4.5" },
        "gpt-5-mini": { "name": "GPT-5 Mini" },
        "gpt-5.2": { "name": "GPT-5.2" },
        "gpt-5.2-codex": { "name": "GPT-5.2 Codex" },
        "gpt-4o": { "name": "GPT-4o" },
        "gemini-3-flash-preview": { "name": "Gemini 3 Flash" },
        "gemini-3.1-pro-preview": { "name": "Gemini 3.1 Pro" }
      }
    }
  },
  "agent": {
    "build": { "disable": true },
    "plan": {
      "model": "github-copilot/claude-opus-4.6",
      "prompt": "{file:./agents/planner.md}",
      "description": "Plans and executes tasks by analyzing requests and delegating to the right subagent.",
      "temperature": 0.4,
      "permission": {
        "task": "allow",
        "read": "allow",
        "edit": "deny",
        "bash": "deny",
        "Playwright*": "allow"
      }
    },
    "investigate": {
      "model": "github-copilot/claude-haiku-4.5",
      "temperature": 0.3
    },
    "agent.explore": {
      "model": "github-copilot/gemini-3-flash-preview",
      "temperature": 0.1,
      "hidden": true
    },
    "agent.fast": {
      "model": "github-copilot/gpt-5-mini",
      "prompt": "{file:./agents/prompts/implementer.md}",
      "description": "Small-scope implementation agent for docs, tests, and bounded edits. Use for quick, low-risk changes with minimal coordination.",
      "temperature": 0.2,
      "hidden": true,
      "permission": {
        "task": "deny",
        "todoread": "deny",
        "todowrite": "deny",
        "Playwright*": "allow"
      }
    },
    "agent.balanced": {
      "model": "github-copilot/gpt-5.2-codex",
      "prompt": "{file:./agents/prompts/implementer.md}",
      "description": "Implementation agent for standard multi-file features, refactors, and non-trivial bugfixes.",
      "temperature": 0.3,
      "hidden": true,
      "permission": {
        "task": "deny",
        "todoread": "deny",
        "todowrite": "deny",
        "Playwright*": "allow"
      }
    },
    "agent.engineer": {
      "model": "github-copilot/claude-opus-4.6",
      "prompt": "{file:./agents/prompts/implementer.md}",
      "description": "Implementation agent for complex, multi-file work and debugging. Use when scope is uncertain, cross-cutting, or requires careful design and verification.",
      "temperature": 0.3,
      "hidden": true,
      "permission": {
        "task": "deny",
        "todoread": "deny",
        "todowrite": "deny",
        "Playwright*": "allow"
      }
    },
    "agent.architect": {
      "model": "github-copilot/gemini-3.1-pro-preview",
      "prompt": "{file:./agents/prompts/implementer.md}",
      "description": "Implementation agent with extra-large context (2M) for the broadest-scope work spanning many files, large-scale refactors, or requiring extended analysis across massive codebases.",
      "temperature": 0.3,
      "hidden": true,
      "permission": {
        "todoread": "deny",
        "todowrite": "deny",
        "task": "deny",
        "Playwright*": "allow"
      }
    }
  },
  "plugin": ["./plugins/skill-preservation.ts"],
  "compaction": {
    "auto": true,
    "prune": true
  },
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "~/.config/opencode/**/*": "allow"
    },
    "list": "allow",
    "glob": "allow",
    "grep": "allow",
    "edit": "allow",
    "skill": "allow",
    "task": "deny",
    "lsp": "allow",
    "question": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "storeread": "allow",
    "storewrite": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "bash": {
      "*": "ask",
      "cat *": "allow",
      "cp *": "allow",
      "rg *": "allow",
      "find *": "allow",
      "wc *": "allow",
      "git *": "allow",
      "git push *": "ask",
      "go build *": "allow",
      "go doc *": "allow",
      "go test *": "allow",
      "go mod *": "allow",
      "go docs *": "allow",
      "go list *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "uniq *": "allow",
      "ls *": "allow",
      "mv *": "ask",
      "rm *": "ask",
      "sort *": "allow",
      "sudo *": "ask",
      "tail *": "allow",
      "timeout *": "allow",
      "task *": "allow",
      "tee *": "allow"
    },
    "external_directory": {
      "*": "ask",
      "/tmp": "allow"
    },
    "doom_loop": "ask",
    "Playwright*": "deny"
  },
  "mcp": {
    "GitHub Grep": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "Deep Wiki": {
      "type": "remote",
      "url": "https://mcp.deepwiki.com/mcp"
    },
    "Playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest",
        "--headless",
        "--allowed-origins",
        "http://localhost:*;https://localhost:*;http://127.0.0.1:*;https://127.0.0.1:*"
      ]
    },
    "ClickUp": {
      "type": "local",
      "command": ["npx", "mcp-remote", "https://mcp.clickup.com/mcp"]
    },
    "GitHub": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": { "Authorization": "Bearer {env:GITHUB_TOKEN}" }
    }
  },
  "autoupdate": true,
  "share": "disabled"
}
