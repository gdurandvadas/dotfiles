{
  "$schema": "https://opencode.ai/config.json",
  "server": {
    "hostname": "127.0.0.1",
    "mdns": false
  },
  "default_agent": "plan",
  "model": "github-copilot/gpt-5-mini",
  "provider": {
    "github-copilot": {
      "models": {}
    }
  },
  "agent": {
    "build": { "disable": true },
    "plan": {
      "model": "github-copilot/gpt-5.2",
      "prompt": "{file:./agents/planner.md}",
      "description": "Plans and executes tasks by analyzing requests and delegating to the right subagent.",
      "temperature": 0.4,
      "permission": {
        "task": "allow",
        "read": "allow",
        "edit": "deny",
        "bash": "deny"
      }
    },
    "investigate": {
      "model": "github-copilot/gpt-5-mini",
      "prompt": "{file:./agents/investigator.md}",
      "temperature": 0.3
    },
    "agent.explore": {
      "model": "github-copilot/gpt-5-mini",
      "prompt": "{file:./agents/subagents/explorer.md}",
      "temperature": 0.1,
      "hidden": true
    },
    "agent.fast": {
      "model": "github-copilot/gpt-5-mini",
      "prompt": "{file:./agents/prompts/implementer.md}",
      "description": "Small-scope implementation agent for docs, tests, and bounded edits. Use for quick, low-risk changes with minimal coordination.",
      "temperature": 0.2,
      "hidden": true,
      "permission": {
        "task": "deny",
        "todoread": "deny",
        "todowrite": "deny"
      }
    },
    "agent.balanced": {
      "model": "github-copilot/gpt-5.2-codex",
      "prompt": "{file:./agents/prompts/implementer.md}",
      "description": "Implementation agent for standard multi-file features, refactors, and non-trivial bugfixes.",
      "temperature": 0.3,
      "hidden": true,
      "permission": {
        "task": "deny",
        "todoread": "deny",
        "todowrite": "deny"
      }
    },
    "agent.engineer": {
      "model": "github-copilot/gpt-5.3-codex",
      "prompt": "{file:./agents/prompts/implementer.md}",
      "description": "Implementation agent for complex, multi-file work and debugging. Use when scope is uncertain, cross-cutting, or requires careful design and verification.",
      "temperature": 0.3,
      "hidden": true,
      "permission": {
        "task": "deny",
        "todoread": "deny",
        "todowrite": "deny"
      }
    },
    "agent.architect": {
      "model": "github-copilot/gpt-5.4",
      "prompt": "{file:./agents/prompts/implementer.md}",
      "description": "Implementation agent with extra-large context (2M) for the broadest-scope work spanning many files, large-scale refactors, or requiring extended analysis across massive codebases.",
      "temperature": 0.3,
      "hidden": true,
      "permission": {
        "todoread": "deny",
        "todowrite": "deny",
        "task": "deny"
      }
    }
  },
  "plugin": ["./plugins/skill-preservation.ts"],
  "compaction": {
    "auto": true,
    "prune": true
  },
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "~/.config/opencode/**/*": "allow"
    },
    "list": "allow",
    "glob": "allow",
    "grep": "allow",
    "edit": "allow",
    "skill": "allow",
    "task": "deny",
    "lsp": "allow",
    "question": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "storeread": "allow",
    "storewrite": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "bash": {
      "*": "ask",
      "cat *": "allow",
      "cp *": "allow",
      "rg *": "allow",
      "find *": "allow",
      "wc *": "allow",
      "git *": "allow",
      "git push *": "ask",
      "go build *": "allow",
      "go doc *": "allow",
      "go test *": "allow",
      "go mod *": "allow",
      "go docs *": "allow",
      "go list *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "uniq *": "allow",
      "ls *": "allow",
      "mv *": "ask",
      "rm *": "ask",
      "sort *": "allow",
      "sudo *": "ask",
      "tail *": "allow",
      "timeout *": "allow",
      "task *": "allow",
      "tee *": "allow"
    },
    "external_directory": {
      "*": "ask",
      "/tmp": "allow"
    },
    "doom_loop": "ask"
  },
  "mcp": {
    "GitHub Grep": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "Deep Wiki": {
      "type": "remote",
      "url": "https://mcp.deepwiki.com/mcp"
    },
    "GitHub": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": { "Authorization": "Bearer {env:GITHUB_TOKEN}" }
    }
  },
  "autoupdate": true,
  "share": "disabled"
}
