{
  "$schema": "https://opencode.ai/config.json",
  "server": {
    "hostname": "127.0.0.1",
    "mdns": false
  },
  "default_agent": "plan",
  "model": "github-copilot/gpt-5-mini",
  "provider": {
    "github-copilot": {
      "models": {
        "gpt-5.3-codex": {
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "limit": {
            "context": 272000,
            "output": 128000
          }
        }
      }
    }
  },
  "agent": {
    "build": { "disable": true },
    "plan": {
      "model": "github-copilot/gpt-5.2",
      "temperature": 0.4
    },
    "investigate": {
      "model": "github-copilot/claude-haiku-4.5",
      "temperature": 0.3
    },
    "orchestrate": {
      "model": "github-copilot/gpt-5.2",
      "description": "Execution orchestrator that delegates to subagents, enforces quality gates, and drives tasks to completion. Can execute plans from plan or handle direct requests.",
      "temperature": 0.3,
      "prompt": "{file:./agents/universal.md}",
      "tools": {
        "Playwright*": true
      },
      "permission": {
        "task": "allow",
        "read": "deny",
        "edit": "deny",
        "bash": "deny"
      }
    },
    "agent.explore": {
      "model": "github-copilot/gemini-3-flash-preview",
      "temperature": 0.1,
      "hidden": true
    },
    "agent.think": {
      "model": "github-copilot/o4-mini",
      "temperature": 0.5,
      "reasoningEffort": "high",
      "hidden": true
    },
    "agent.fast": {
      "model": "github-copilot/gemini-3-flash-preview",
      "prompt": "{file:./agents/prompts/implementer.md}",
      "description": "Small-scope implementation agent for docs, tests, and bounded edits. Use for quick, low-risk changes with minimal coordination.",
      "temperature": 0.2,
      "hidden": true,
      "permission": {
        "task": "deny",
        "todoread": "deny",
        "todowrite": "deny",
        "Playwright*": "allow"
      }
    },
    "agent.balanced": {
      "model": "github-copilot/gpt-5.2-codex",
      "prompt": "{file:./agents/prompts/implementer.md}",
      "description": "Implementation agent for standard multi-file features, refactors, and non-trivial bugfixes.",
      "temperature": 0.3,
      "hidden": true,
      "permission": {
        "task": "deny",
        "todoread": "deny",
        "todowrite": "deny",
        "Playwright*": "allow"
      }
    },
    "agent.deep": {
      "model": "github-copilot/claude-opus-4.6",
      "prompt": "{file:./agents/prompts/implementer.md}",
      "description": "Implementation agent for complex, multi-file work and debugging. Use when scope is uncertain, cross-cutting, or requires careful design and verification.",
      "temperature": 0.3,
      "hidden": true,
      "permission": {
        "task": "deny",
        "todoread": "deny",
        "todowrite": "deny",
        "Playwright*": "allow"
      }
    },
    "agent.deep-l": {
      "disable": false,
      "model": "github-copilot/gpt-5.3-codex",
      "prompt": "{file:./agents/prompts/implementer.md}",
      "description": "Implementation agent with large context (272k) for broad-scope work spanning many files or requiring extended analysis.",
      "temperature": 0.3,
      "hidden": true,
      "permission": {
        "todoread": "deny",
        "todowrite": "deny",
        "task": "deny",
        "Playwright*": "allow"
      }
    },
    "agent.deep-xl": {
      "disable": false,
      "model": "github-copilot/gemini-3.1-pro",
      "prompt": "{file:./agents/prompts/implementer.md}",
      "description": "Implementation agent with extra-large context (2M) for the broadest-scope work spanning many files or requiring extended analysis.",
      "temperature": 0.3,
      "hidden": true,
      "permission": {
        "todoread": "deny",
        "todowrite": "deny",
        "task": "deny",
        "Playwright*": "allow"
      }
    }
  },
  "plugin": ["./plugins/skill-preservation.ts"],
  "compaction": {
    "auto": true,
    "prune": true
  },
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "~/.config/opencode/**/*": "allow"
    },
    "list": "allow",
    "glob": "allow",
    "grep": "allow",
    "edit": "allow",
    "skill": "allow",
    "task": "deny",
    "lsp": "allow",
    "question": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "storeread": "allow",
    "storewrite": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "bash": {
      "*": "ask",
      "cat *": "allow",
      "cp *": "allow",
      "rg *": "allow",
      "find *": "allow",
      "wc *": "allow",
      "git *": "allow",
      "git push *": "ask",
      "go build *": "allow",
      "go doc *": "allow",
      "go test *": "allow",
      "go mod *": "allow",
      "go docs *": "allow",
      "go list *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "uniq *": "allow",
      "ls *": "allow",
      "mv *": "ask",
      "rm *": "ask",
      "sort *": "allow",
      "sudo *": "ask",
      "tail *": "allow",
      "timeout *": "allow",
      "task *": "allow",
      "tee *": "allow"
    },
    "external_directory": {
      "*": "ask",
      "/tmp": "allow"
    },
    "doom_loop": "ask",
    "Playwright*": "deny"
  },
  "mcp": {
    "GitHub Grep": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "Deep Wiki": {
      "type": "remote",
      "url": "https://mcp.deepwiki.com/mcp"
    },
    "Playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest",
        "--headless",
        "--allowed-origins",
        "http://localhost:*;https://localhost:*;http://127.0.0.1:*;https://127.0.0.1:*"
      ]
    },
    "ClickUp": {
      "type": "local",
      "command": ["npx", "mcp-remote", "https://mcp.clickup.com/mcp"]
    },
    "GitHub": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": { "Authorization": "Bearer {env:GITHUB_TOKEN}" }
    }
  },
  "autoupdate": true,
  "share": "disabled"
}
