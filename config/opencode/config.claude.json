{
  "$schema": "https://opencode.ai/config.json",
  "server": {
    "hostname": "127.0.0.1",
    "mdns": false
  },
  "default_agent": "plan",
  "model": "claude-haiku-4-5",
  "agent": {
    "build": { "disable": true },
    "plan": {
      "model": "claude-sonnet-4-6",
      "prompt": "{file:./agents/personal/planner.md}",
      "description": "Research and task breakdown. Explores the codebase and produces a structured plan for @orchestrate to execute.",
      "temperature": 0.4,
      "max_tokens": 4000,
      "permission": {
        "task": {
          "*": "deny",
          "agent.explore": "allow"
        },
        "read": "allow",
        "edit": "deny",
        "bash": "deny"
      }
    },
    "orchestrate": {
      "model": "claude-sonnet-4-6",
      "prompt": "{file:./agents/personal/orchestrator.md}",
      "description": "Execution orchestrator. Takes a plan and delegates tasks to the right implementation agents.",
      "temperature": 0.3,
      "max_tokens": 2000,
      "permission": {
        "task": "allow",
        "read": "allow",
        "edit": "deny",
        "bash": "deny"
      }
    },
    "investigate": {
      "model": "claude-haiku-4-5",
      "prompt": "{file:./agents/shared/investigator.md}",
      "temperature": 0.3,
      "max_tokens": 3000
    },
    "agent.explore": {
      "model": "claude-haiku-4-5",
      "prompt": "{file:./agents/shared/explorer.md}",
      "temperature": 0.1,
      "max_tokens": 1500,
      "hidden": true
    },
    "agent.swift": {
      "model": "claude-haiku-4-5",
      "prompt": "{file:./agents/prompts/implementer.md}",
      "description": "Fast implementation agent for self-contained edits: single-file changes, docs, tests, trivial bugfixes.",
      "temperature": 0.2,
      "max_tokens": 2000,
      "hidden": true,
      "permission": {
        "task": "deny",
        "todoread": "deny",
        "todowrite": "deny"
      }
    },
    "agent.craft": {
      "model": "claude-sonnet-4-6",
      "prompt": "{file:./agents/prompts/implementer.md}",
      "description": "Standard implementation agent for multi-file features, refactors, and non-trivial bugfixes.",
      "temperature": 0.3,
      "max_tokens": 4000,
      "hidden": true,
      "permission": {
        "task": "deny",
        "todoread": "deny",
        "todowrite": "deny"
      }
    },
    "agent.forge": {
      "model": "claude-opus-4-7",
      "prompt": "{file:./agents/prompts/implementer.md}",
      "description": "Advanced implementation agent for complex, cross-cutting work: large-scale refactors, uncertain scope, deep debugging.",
      "temperature": 0.3,
      "max_tokens": 8000,
      "hidden": true,
      "permission": {
        "task": "deny",
        "todoread": "deny",
        "todowrite": "deny"
      }
    }
  },
  "plugin": ["./plugins/skill-preservation.ts", "opencode-claude-auth@latest"],
  "compaction": {
    "auto": true,
    "prune": true
  },
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "~/.config/opencode/**/*": "allow"
    },
    "list": "allow",
    "glob": "allow",
    "grep": "allow",
    "edit": "allow",
    "skill": "allow",
    "task": "deny",
    "lsp": "allow",
    "question": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "storeread": "allow",
    "storewrite": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "bash": {
      "*": "ask",
      "cat *": "allow",
      "cp *": "allow",
      "rg *": "allow",
      "find *": "allow",
      "wc *": "allow",
      "git *": "allow",
      "git push *": "ask",
      "go build *": "allow",
      "go doc *": "allow",
      "go test *": "allow",
      "go mod *": "allow",
      "go docs *": "allow",
      "go list *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "uniq *": "allow",
      "ls *": "allow",
      "mv *": "ask",
      "rm *": "ask",
      "sort *": "allow",
      "sudo *": "ask",
      "tail *": "allow",
      "timeout *": "allow",
      "task *": "allow",
      "tee *": "allow"
    },
    "external_directory": {
      "*": "ask",
      "/tmp": "allow"
    },
    "doom_loop": "ask"
  },
  "mcp": {
    "GitHub Grep": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "Deep Wiki": {
      "type": "remote",
      "url": "https://mcp.deepwiki.com/mcp"
    },
    "GitHub": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": { "Authorization": "Bearer {env:GITHUB_TOKEN}" }
    }
  },
  "autoupdate": true,
  "share": "disabled"
}
