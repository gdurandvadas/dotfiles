{
  "git_panel": {
    "sort_by_path": true,
    "tree_view": true
  },
  "agent": {
    "default_model": {
      "effort": "high",
      "provider": "copilot_chat",
      "model": "gpt-5.4",
    },
    "model_parameters": [],
  },
  "terminal": {
    "font_family": "FiraCode Nerd Font Propo",
  },
  "format_on_save": "on",
  "auto_install_extensions": {
    "nix": true,
    "sql": true,
    "glsl": true,
    "helm": true,
    "html": true,
    "make": true,
    "toml": true,
    "biome": true,
    "proto": true,
    "direnv": true,
    "kotlin": true,
    "clojure": true,
    "gdscript": true,
    "surrealql": true,
    "terraform": true,
    "catppuccin": true,
    "dockerfile": true,
    "catppuccin-icons": true,
    "claude-agent": true,
  },
  // Theming
  "theme": {
    "mode": "system",
    "light": "Catppuccin Frappé",
    "dark": "Catppuccin Mocha",
  },
  "icon_theme": {
    "mode": "system",
    "light": "Catppuccin Frappé",
    "dark": "Catppuccin Mocha",
  },
  // Typography
  "ui_font_size": 13,
  "buffer_font_size": 12.0,
  "agent_ui_font_size": 12,
  "agent_buffer_font_size": 12.0,

  // Agents
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
    "OpenCode": {
      "type": "custom",
      "command": "opencode",
      "args": ["acp"],
    },
  },

  // Language-specific settings
  "languages": {
    "Go": {
      "language_servers": ["gopls"],
      "format_on_save": "on",
      "tab_size": 4,
    },
    "Rust": {
      "language_servers": ["rust-analyzer"],
      "format_on_save": "on",
    },
    "TypeScript": {
      "language_servers": ["vtsls"],
      "format_on_save": "on",
      "tab_size": 2,
    },
    "JavaScript": {
      "language_servers": ["vtsls"],
      "format_on_save": "on",
      "tab_size": 2,
    },
    "Nix": {
      "language_servers": ["nixd"],
      "format_on_save": "on",
      "tab_size": 2,
    },
  },
  // LSP overrides
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "checkOnSave": true,
        "check": {
          "command": "clippy",
        },
      },
    },
    "gopls": {
      "initialization_options": {
        "hints": {
          "parameterNames": true,
          "rangeVariableTypes": true,
        },
      },
    },
  },
}
